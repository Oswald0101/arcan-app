# ============================================================
# VOIE APP — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ============================================================

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---- Prisma ----
# Pooler (transactions, prisma client) — port 6543 avec pgbouncer=true
DATABASE_URL=postgresql://postgres.xxxxx:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct (migrations) — port 5432
DIRECT_URL=postgresql://postgres.xxxxx:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Anthropic / Guide IA ----
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-haiku-4-5-20251001
AI_PROVIDER=anthropic

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
