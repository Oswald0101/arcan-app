  id             String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  reporterUserId String           @map("reporter_user_id") @db.Uuid
  targetType     ReportTargetType @map("target_type")
  targetId       String           @map("target_id") @db.Uuid
  reasonKey      String           @map("reason_key")
  detailsText    String?          @map("details_text")
  status         ReportStatus     @default(pending)
  assignedTo     String?          @map("assigned_to") @db.Uuid
  moderatorNote  String?          @map("moderator_note")
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz
  resolvedAt     DateTime?        @map("resolved_at") @db.Timestamptz

  reporter           User               @relation("ReportReporter", fields: [reporterUserId], references: [id], onDelete: Cascade)
  assignedModerator  User?              @relation("ReportAssigned", fields: [assignedTo], references: [id], onDelete: SetNull)
  moderationActions  ModerationAction[]

  @@index([status])
  @@index([targetType, targetId])
  @@map("reports")
}

model ModerationAction {
  id              String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  moderatorUserId String               @map("moderator_user_id") @db.Uuid
  reportId        String?              @map("report_id") @db.Uuid
  targetType      String               @map("target_type")
  targetId        String               @map("target_id") @db.Uuid
  actionType      ModerationActionType @map("action_type")
  reasonText      String               @map("reason_text")
  expiresAt       DateTime?            @map("expires_at") @db.Timestamptz
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz

  moderator User    @relation("ModerationModerator", fields: [moderatorUserId], references: [id], onDelete: Restrict)
  report    Report? @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@map("moderation_actions")
}

model Block {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  blockerUserId String   @map("blocker_user_id") @db.Uuid
  blockedUserId String   @map("blocked_user_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz

  blocker User @relation("BlockBlocker", fields: [blockerUserId], references: [id], onDelete: Cascade)
  blocked User @relation("BlockBlocked", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([blockerUserId, blockedUserId])
  @@map("blocks")
}

model VerificationRequest {
  id             String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId         String                    @map("user_id") @db.Uuid
  requestType    VerificationRequestType   @default(standard) @map("request_type")
  status         VerificationRequestStatus @default(pending)
  submittedData  Json                      @default("{}") @map("submitted_data")
  reviewerUserId String?                   @map("reviewer_user_id") @db.Uuid
  reviewerNote   String?                   @map("reviewer_note")
  createdAt      DateTime                  @default(now()) @map("created_at") @db.Timestamptz
  reviewedAt     DateTime?                 @map("reviewed_at") @db.Timestamptz

  user     User  @relation("VerificationUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("VerificationReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@map("verification_requests")
}

model AgeConsent {
  id                      String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId                  String   @unique @map("user_id") @db.Uuid
  declaredAgeGroup        String   @default("adult") @map("declared_age_group")
  declaredAt              DateTime @default(now()) @map("declared_at") @db.Timestamptz
  parentalConsentRequired Boolean  @default(false) @map("parental_consent_required")
  parentalConsentStatus   String   @default("not_required") @map("parental_consent_status")
  parentalEmail           String?  @map("parental_email")
  consentReference        String?  @map("consent_reference")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("age_consents")
}

// ============================================================
// BLOC J — Admin et analytics
// ============================================================

model AdminRole {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  roleKey     String   @unique @map("role_key")
  title       String
  description String?
  permissions Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  userAdminRoles UserAdminRole[]

  @@map("admin_roles")
}

model UserAdminRole {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  adminRoleId      String   @map("admin_role_id") @db.Uuid
  grantedByUserId  String?  @map("granted_by_user_id") @db.Uuid
  grantedAt        DateTime @default(now()) @map("granted_at") @db.Timestamptz
  isActive         Boolean  @default(true) @map("is_active")

  user      User      @relation("AdminRoleUser", fields: [userId], references: [id], onDelete: Cascade)
  adminRole AdminRole @relation(fields: [adminRoleId], references: [id], onDelete: Restrict)
  grantedBy User?     @relation("AdminRoleGranter", fields: [grantedByUserId], references: [id], onDelete: SetNull)

  @@unique([userId, adminRoleId])
  @@map("user_admin_roles")
}

model AdminNote {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  targetType   String   @map("target_type")
  targetId     String   @map("target_id") @db.Uuid
  authorUserId String   @map("author_user_id") @db.Uuid
  content      String
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  author User @relation("AdminNoteAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([targetType, targetId])
  @@map("admin_notes")
}

model SystemSetting {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  settingKey       String   @unique @map("setting_key")
  settingValue     Json     @map("setting_value")
  description      String?
  updatedByUserId  String?  @map("updated_by_user_id") @db.Uuid
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("system_settings")
}

model AuditLog {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  actorUserId  String?  @map("actor_user_id") @db.Uuid
  actorType    String   @default("user") @map("actor_type")
  actionKey    String   @map("action_key")
  targetType   String?  @map("target_type")
  targetId     String?  @map("target_id") @db.Uuid
  metadata     Json     @default("{}")
  ipHash       String?  @map("ip_hash")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  actor User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt(sort: Desc)])
  @@index([targetType, targetId, createdAt(sort: Desc)])
  @@index([actionKey, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

model AnalyticsEvent {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  eventKey   String   @map("event_key")
  eventData  Json     @default("{}") @map("event_data")
  sessionId  String?  @map("session_id")
  platform   String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventKey, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("analytics_events")
}
