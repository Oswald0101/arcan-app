  responseText   String?  @map("response_text")
  score          Decimal  @map("score") @db.Decimal(4, 3)
  xpAwarded      Int      @map("xp_awarded")
  // Flags anti-triche : too_fast | no_text | low_quality_text | repeated_response | daily_cap_reached
  flags          String[]
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  practice Practice @relation(fields: [practiceId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("practice_validations")
}

