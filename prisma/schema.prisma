// ============================================================
// VOIE APP — Prisma Schema
// Database: PostgreSQL (Supabase)
// Generator: prisma-client-js
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [uuidOssp(map: "uuid-ossp"), pgcrypto]
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  member
  founder
  moderator
  admin
  super_admin

  @@map("user_role")
}

enum AccountStatus {
  pending
  active
  suspended
  banned
  deleted

  @@map("account_status")
}

enum VerificationBadge {
  none
  verified
  founder_verified

  @@map("verification_badge")
}

enum LanguageCode {
  fr
  en
  es
  pt

  @@map("language_code")
}

enum ThemeMode {
  dark
  light
  system

  @@map("theme_mode")
}

enum NotificationLevel {
  all
  important
  minimal
  none

  @@map("notification_level")
}

enum GuideAddressMode {
  tutoiement
  vouvoiement

  @@map("guide_address_mode")
}

enum OnboardingStatus {
  started
  in_progress
  completed
  abandoned

  @@map("onboarding_status")
}

enum QuestionType {
  free_text
  single_choice
  multi_choice
  scale

  @@map("question_type")
}

enum PathCanonicalType {
  voie
  religion
  mouvement
  philosophie
  ordre
  tradition
  courant
  ecole
  cercle_type
  temple
  doctrine
  culte
  autre

  @@map("path_canonical_type")
}

enum GuideCanonicalType {
  guide
  dieu
  presence
  source
  gardien
  maitre
  oracle
  voix
  force
  flamme
  conscience
  esprit
  principe
  autre

  @@map("guide_canonical_type")
}

enum PathVisibility {
  public
  unlisted
  private

  @@map("path_visibility")
}

enum AdmissionMode {
  open
  on_request
  invite_only

  @@map("admission_mode")
}

enum PathStatus {
  active
  archived
  suspended

  @@map("path_status")
}

enum GuideTone {
  direct
  doux
  philosophique
  stoique
  mystique
  socratique
  solennel
  fraternel
  sobre
  inspirant

  @@map("guide_tone")
}

enum MembershipRole {
  member
  elder
  moderator
  founder

  @@map("membership_role")
}

enum MembershipStatus {
  pending
  active
  suspended
  left
  banned

  @@map("membership_status")
}

enum Difficulty {
  easy
  medium
  hard

  @@map("difficulty")
}

enum PracticeFrequency {
  daily
  weekly
  monthly
  custom

  @@map("practice_frequency")
}

enum LogStatus {
  in_progress
  completed
  failed
  skipped

  @@map("log_status")
}

enum SenderType {
  member
  guide
  system

  @@map("sender_type")
}

enum ConversationStatus {
  active
  archived

  @@map("conversation_status")
}

enum MemoryType {
  commitment
  struggle
  progress
  preference
  context
  keyword
  warning

  @@map("memory_type")
}

enum CodexType {
  personal
  path
  guide

  @@map("codex_type")
}

enum CodexStatus {
  draft
  published
  archived

  @@map("codex_status")
}

enum CodexOrderType {
  pdf_export
  premium_edition
  print

  @@map("codex_order_type")
}

enum CodexOrderStatus {
  pending
  processing
  completed
  failed
  refunded

  @@map("codex_order_status")
}

enum ContactStatus {
  pending
  accepted
  rejected
  blocked

  @@map("contact_status")
}

enum FollowTargetType {
  user
  path

  @@map("follow_target_type")
}

enum InviteStatus {
  pending
  accepted
  expired
  cancelled

  @@map("invite_status")
}

enum InviteType {
  app
  path

  @@map("invite_type")
}

enum NotificationType {
  guide_message
  daily_practice
  challenge_reminder
  contact_request
  new_message
  rank_up
  level_up
  badge_earned
  invite_accepted
  system

  @@map("notification_type")
}

enum BillingPeriod {
  monthly
  yearly
  lifetime
  one_time

  @@map("billing_period")
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  canceled
  expired

  @@map("subscription_status")
}

enum ProductType {
  avatar_pack
  guide_skin
  theme
  practice_pack
  challenge_pack
  codex_export
  codex_premium_edition
  subscription_upgrade

  @@map("product_type")
}

enum PurchaseStatus {
  pending
  completed
  refunded
  failed

  @@map("purchase_status")
}

enum EntitlementSource {
  subscription
  purchase
  referral
  admin_grant

  @@map("entitlement_source")
}

enum ReportTargetType {
  user
  path
  guide_message
  direct_message
  codex

  @@map("report_target_type")
}

enum ReportStatus {
  pending
  under_review
  resolved_no_action
  resolved_action_taken
  dismissed

  @@map("report_status")
}

enum ModerationActionType {
  warning
  content_removed
  suspend
  ban
  path_suspended
  path_deleted

  @@map("moderation_action_type")
}

enum VerificationRequestType {
  standard
  founder

  @@map("verification_request_type")
}

enum VerificationRequestStatus {
  pending
  approved
  rejected
  more_info_needed

  @@map("verification_request_status")
}

// ============================================================
// BLOC A — Comptes et identité
// ============================================================

// Note : auth.users est géré par Supabase — on le référence via @db.Uuid
// Prisma ne modélise pas auth.users directement

model User {
  id            String        @id @db.Uuid
  role          UserRole      @default(member)
  accountStatus AccountStatus @default(pending) @map("account_status")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  lastLoginAt   DateTime?     @map("last_login_at") @db.Timestamptz
  deletedAt     DateTime?     @map("deleted_at") @db.Timestamptz

  // Relations
  profile                 Profile?
  codexVersionsCreated CodexVersion[]
  preferences             UserPreference?
  legalConsents           LegalConsent[]
  onboardingSessions      OnboardingSession[]
  onboardingAnswers       OnboardingAnswer[]
  sensitivityProfile      UserSensitivityProfile?
  foundedPaths            Path[]                   @relation("PathFounder")
  guides                  Guide[]                  @relation("GuideOwner")
  memberProgress          UserMemberProgress?
  pathProgresses          UserPathProgress[]
  practiceLogs            UserPracticeLog[]
  practiceValidations     PracticeValidation[]
  challengeLogs           UserChallengeLog[]
  userBadges              UserBadge[]
  guideConversations      GuideConversation[]
  guideMemoryItems        GuideMemoryItem[]
  codexes                 Codex[]                  @relation("CodexOwner")
  manifestos              Manifesto[]              @relation("ManifestoOwner")
  principles              Principle[]              @relation("PrincipleOwner")
  codexOrders             CodexOrder[]
  sentContactRequests     ContactRequest[]         @relation("ContactSender")
  receivedContactRequests ContactRequest[]         @relation("ContactReceiver")
  contactsAsOne           Contact[]                @relation("ContactUserOne")
  contactsAsTwo           Contact[]                @relation("ContactUserTwo")
  conversationsAsOne      DirectConversation[]     @relation("DirectConvUserOne")
  conversationsAsTwo      DirectConversation[]     @relation("DirectConvUserTwo")
  directMessagesSent      DirectMessage[]
  follows                 Follow[]
  invitesSent             Invite[]                 @relation("InviteInviter")
  inviteAccepted          Invite?                  @relation("InviteAccepted")
  referralRewardsGiven    ReferralReward[]         @relation("ReferralInviter")
  referralRewardsReceived ReferralReward[]         @relation("ReferralInvitee")
  notifications           Notification[]
  subscriptions           UserSubscription[]
  purchases               Purchase[]
  entitlements            UserEntitlement[]
  reports                 Report[]                 @relation("ReportReporter")
  blocksGiven             Block[]                  @relation("BlockBlocker")
  blocksReceived          Block[]                  @relation("BlockBlocked")
  verificationRequests    VerificationRequest[]    @relation("VerificationUser")
  ageConsent              AgeConsent?
  adminRoles              UserAdminRole[]          @relation("AdminRoleUser")
  adminNotes              AdminNote[]              @relation("AdminNoteAuthor")
  auditLogs               AuditLog[]               @relation("AuditActor")
  analyticsEvents         AnalyticsEvent[]
  // Relations admin (reviewer, approver...)
  memberships             CircleMembership[]
  invitedMemberships      CircleMembership[]       @relation("MembershipInviter")
  approvedMemberships     CircleMembership[]       @relation("MembershipApprover")
  pathVersionsCreated     PathVersion[]
  assignedReports         Report[]                 @relation("ReportAssigned")
  moderationActions       ModerationAction[]       @relation("ModerationModerator")
  verificationReviews     VerificationRequest[]    @relation("VerificationReviewer")
  adminRolesGranted       UserAdminRole[]          @relation("AdminRoleGranter")
  foundedCircles          Circle[]                 @relation("CircleFounder")

  @@map("users")
}

model Profile {
  id                   String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId               String            @unique @map("user_id") @db.Uuid
  username             String            @unique
  displayName          String?           @map("display_name")
  bio                  String?
  avatarType           String            @default("preset") @map("avatar_type")
  avatarUrl            String?           @map("avatar_url")
  country              String?
  city                 String?
  language             LanguageCode      @default(fr)
  timezone             String            @default("UTC")
  isPublic             Boolean           @default(true) @map("is_public")
  showLocation         Boolean           @default(false) @map("show_location")
  showPath             Boolean           @default(true) @map("show_path")
  showGuide            Boolean           @default(false) @map("show_guide")
  showLevel            Boolean           @default(true) @map("show_level")
  verificationStatus   VerificationBadge @default(none) @map("verification_status")
  onboardingCompleted  Boolean           @default(false) @map("onboarding_completed")
  onboardingCompletedAt DateTime?        @map("onboarding_completed_at") @db.Timestamptz
  currentLevel         Int               @default(1) @map("current_level")
  currentXp            Int               @default(0) @map("current_xp")
  createdAt            DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model UserPreference {
  id                String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId            String            @unique @map("user_id") @db.Uuid
  language          LanguageCode      @default(fr)
  themeMode         ThemeMode         @default(dark) @map("theme_mode")
  soundEnabled      Boolean           @default(true) @map("sound_enabled")
  hapticsEnabled    Boolean           @default(true) @map("haptics_enabled")
  notificationLevel NotificationLevel @default(important) @map("notification_level")
  guideAddressMode  GuideAddressMode  @default(tutoiement) @map("guide_address_mode")
  extraPrefs        Json              @default("{}") @map("extra_prefs")
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model LegalConsent {
  id             String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  consentType    String   @map("consent_type")
  consentVersion String   @map("consent_version")
  accepted       Boolean  @default(true)
  acceptedAt     DateTime @default(now()) @map("accepted_at") @db.Timestamptz
  ipHash         String?  @map("ip_hash")
  userAgentHash  String?  @map("user_agent_hash")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("legal_consents")
}

// ============================================================
// BLOC B — Onboarding
// ============================================================

model OnboardingSession {
  id                      String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId                  String           @map("user_id") @db.Uuid
  status                  OnboardingStatus @default(started)
  currentBloc             Int              @default(1) @map("current_bloc")
  version                 String           @default("1.0")
  startedAt               DateTime         @default(now()) @map("started_at") @db.Timestamptz
  completedAt             DateTime?        @map("completed_at") @db.Timestamptz
  generatedProfileSnapshot Json?           @map("generated_profile_snapshot")

  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers OnboardingAnswer[]
  sensitivityProfile UserSensitivityProfile?

  @@map("onboarding_sessions")
}

model OnboardingAnswer {
  id            String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  sessionId     String       @map("session_id") @db.Uuid
  userId        String       @map("user_id") @db.Uuid
  blocNumber    Int          @map("bloc_number")
  questionKey   String       @map("question_key")
  questionType  QuestionType @map("question_type")
  answerText    String?      @map("answer_text")
  answerChoice  String?      @map("answer_choice")
  answerChoices String[]     @map("answer_choices")
  answerScale   Int?         @map("answer_scale")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz

  session OnboardingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionKey])
  @@map("onboarding_answers")
}

model UserSensitivityProfile {
  id                    String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId                String   @unique @db.Uuid
  sessionId             String?  @unique @map("session_id") @db.Uuid
  needForStructure      Decimal? @map("need_for_structure") @db.Decimal(3, 2)
  needForMeaning        Decimal? @map("need_for_meaning") @db.Decimal(3, 2)
  spiritualAffinity     Decimal? @map("spiritual_affinity") @db.Decimal(3, 2)
  symbolicAffinity      Decimal? @map("symbolic_affinity") @db.Decimal(3, 2)
  rationalAffinity      Decimal? @map("rational_affinity") @db.Decimal(3, 2)
  communityDesire       Decimal? @map("community_desire") @db.Decimal(3, 2)
  confrontationPref     Decimal? @map("confrontation_preference") @db.Decimal(3, 2)
  softnessPref          Decimal? @map("softness_preference") @db.Decimal(3, 2)
  commitmentLevel       Decimal? @map("commitment_level") @db.Decimal(3, 2)
  emotionalStability    Decimal? @map("emotional_stability") @db.Decimal(3, 2)
  creationDesire        Decimal? @map("creation_desire") @db.Decimal(3, 2)
  generatedSummary      String?  @map("generated_summary")
  extractedKeywords     String[] @map("extracted_keywords")
  symbolicAffinities    String[] @map("symbolic_affinities")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  session OnboardingSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@map("user_sensitivity_profiles")
}

// ============================================================
// BLOC C — Voies, guides, cercles
// ============================================================

model Path {
  id               String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  founderUserId    String            @map("founder_user_id") @db.Uuid
  canonicalType    PathCanonicalType @default(voie) @map("canonical_type")
  customTypeLabel  String?           @map("custom_type_label")
  name             String
  slug             String            @unique
  shortDescription String            @map("short_description")
  longDescription  String?           @map("long_description")
  language         LanguageCode      @default(fr)
  status           PathStatus        @default(active)
  visibility       PathVisibility    @default(public)
  admissionMode    AdmissionMode     @default(open) @map("admission_mode")
  primaryTheme     String?           @map("primary_theme")
  symbolicStyle    String?           @map("symbolic_style")
  memberCount      Int               @default(0) @map("member_count")
  currentVersion   Int               @default(1) @map("current_version")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  founder       User           @relation("PathFounder", fields: [founderUserId], references: [id], onDelete: Restrict)
  versions      PathVersion[]
  circle        Circle?
  ranks         PathRank[]
  practices     Practice[]
  challenges    Challenge[]
  manifestos    Manifesto[]    @relation("ManifestoPath")
  principles    Principle[]    @relation("PrinciplePath")
  guides        Guide[]
  codexes       Codex[]        @relation("CodexPath")
  pathProgresses UserPathProgress[]
  invites       Invite[]

  @@index([visibility])
  @@index([founderUserId])
  @@index([status])
  @@map("paths")
}

model PathVersion {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  pathId          String   @map("path_id") @db.Uuid
  versionNumber   Int      @map("version_number")
  manifestoText   String?  @map("manifesto_text")
  principles      String[]
  practices       String[]
  evolutionNotes  String?  @map("evolution_notes")
  createdByUserId String   @map("created_by_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  path      Path @relation(fields: [pathId], references: [id], onDelete: Cascade)
  createdBy User @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@unique([pathId, versionNumber])
  @@map("path_versions")
}

model Guide {
  id               String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  ownerUserId      String             @map("owner_user_id") @db.Uuid
  pathId           String?            @map("path_id") @db.Uuid
  canonicalType    GuideCanonicalType @default(guide) @map("canonical_type")
  customTypeLabel  String?            @map("custom_type_label")
  name             String
  memberName       String?            @map("member_name")
  tone             GuideTone          @default(direct)
  addressMode      GuideAddressMode   @default(tutoiement) @map("address_mode")
  firmnessLevel    Int                @default(3) @map("firmness_level")
  warmthLevel      Int                @default(3) @map("warmth_level")
  symbolicIdentity String?            @map("symbolic_identity")
  avatarAssetUrl   String?            @map("avatar_asset_url")
  personalityPrompt String            @map("personality_prompt")
  memorySummary    String?            @map("memory_summary")
  currentVersion   Int                @default(1) @map("current_version")
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  owner         User               @relation("GuideOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  path          Path?              @relation(fields: [pathId], references: [id], onDelete: SetNull)
  versions      GuideVersion[]
  conversations GuideConversation[]
  memoryItems   GuideMemoryItem[]
  codexes       Codex[]            @relation("CodexGuide")

  @@map("guides")
}

model GuideVersion {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  guideId          String    @map("guide_id") @db.Uuid
  versionNumber    Int       @map("version_number")
  tone             GuideTone
  firmnessLevel    Int       @map("firmness_level")
  warmthLevel      Int       @map("warmth_level")
  personalityPrompt String   @map("personality_prompt")
  changeSummary    String?   @map("change_summary")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz

  guide Guide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@unique([guideId, versionNumber])
  @@map("guide_versions")
}

model Circle {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  pathId        String   @unique @map("path_id") @db.Uuid
  founderUserId String   @map("founder_user_id") @db.Uuid
  name          String?
  description   String?
  memberCount   Int      @default(0) @map("member_count")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  path        Path               @relation(fields: [pathId], references: [id], onDelete: Cascade)
  founder     User               @relation("CircleFounder", fields: [founderUserId], references: [id], onDelete: Restrict)
  memberships CircleMembership[]

  @@map("circles")
}

model CircleMembership {
  id               String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  circleId         String           @map("circle_id") @db.Uuid
  userId           String           @map("user_id") @db.Uuid
  role             MembershipRole   @default(member)
  status           MembershipStatus @default(active)
  joinedAt         DateTime         @default(now()) @map("joined_at") @db.Timestamptz
  invitedByUserId  String?          @map("invited_by_user_id") @db.Uuid
  approvedByUserId String?          @map("approved_by_user_id") @db.Uuid

  circle      Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy   User?  @relation("MembershipInviter", fields: [invitedByUserId], references: [id], onDelete: SetNull)
  approvedBy  User?  @relation("MembershipApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@unique([circleId, userId])
  @@index([circleId, status])
  @@index([userId, status])
  @@map("circle_memberships")
}

// ============================================================
// BLOC D — Progression
// ============================================================

model MemberLevel {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  levelNumber  Int      @unique @map("level_number")
  title        String
  requiredXp   Int      @map("required_xp")
  badgeUrl     String?  @map("badge_url")
  perks        Json     @default("[]")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  usersAtLevel UserMemberProgress[]

  @@map("member_levels")
}

model UserMemberProgress {
  id                       String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId                   String    @unique @map("user_id") @db.Uuid
  currentLevelId           String?   @map("current_level_id") @db.Uuid
  currentXp                Int       @default(0) @map("current_xp")
  streakDays               Int       @default(0) @map("streak_days")
  longestStreak            Int       @default(0) @map("longest_streak")
  totalPracticesCompleted  Int       @default(0) @map("total_practices_completed")
  totalChallengesCompleted Int       @default(0) @map("total_challenges_completed")
  totalDaysActive          Int       @default(0) @map("total_days_active")
  lastActivityAt           DateTime? @map("last_activity_at") @db.Timestamptz
  updatedAt                DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentLevel MemberLevel? @relation(fields: [currentLevelId], references: [id], onDelete: SetNull)

  @@map("user_member_progress")
}

model PathRank {
  id                 String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  pathId             String   @map("path_id") @db.Uuid
  rankOrder          Int      @map("rank_order")
  title              String
  description        String?
  requiredXp         Int      @default(0) @map("required_xp")
  requiredConditions Json     @default("{}") @map("required_conditions")
  badgeUrl           String?  @map("badge_url")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz

  path            Path                 @relation(fields: [pathId], references: [id], onDelete: Cascade)
  usersAtRank     UserPathProgress[]

  @@unique([pathId, rankOrder])
  @@map("path_ranks")
}

model UserPathProgress {
  id                   String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId               String    @map("user_id") @db.Uuid
  pathId               String    @map("path_id") @db.Uuid
  currentRankId        String?   @map("current_rank_id") @db.Uuid
  rankXp               Int       @default(0) @map("rank_xp")
